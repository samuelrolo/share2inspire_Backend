# Ficheiro .env.example para o projeto Share2Inspire Backend

# Chaves API Brevo (Sendinblue)
BREVO_API_KEY="sua_chave_brevo_aqui"
BREVO_SENDER_EMAIL=email@dominio.com
BREVO_SENDER_NAME=Nome

# Chaves API IfthenPay
IFTHENPAY_GATEWAY_KEY="_gateway_key_aqui" 
IFTHENPAY_CALLBACK_KEY="_callback_key_aqui"
IFTHENPAY_MBWAY_KEY=_mbway_key
IFTHENPAY_PAYSHOP_KEY=_payshop_key
IFTHENPAY_MB_KEY=_mb_key

# Configuração Flask
FLASK_SECRET_KEY="_chave_secreta_"
FLASK_DEBUG=False
FLASK_ENV=production

# URL do Backend (para callbacks)
BACKEND_URL=https://backend.appspot.com

# URL do Google Calendar
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/sua_url_aqui/exec

# Anti-Phishing Key (se necessário)
ANTI_PHISHING_KEY="_anti_phishing_key_"

